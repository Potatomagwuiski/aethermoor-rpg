generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id // Discord User ID
  level        Int      @default(1)
  xp           Int      @default(0)
  
  // Base Attributes
  strength     Int @default(5)
  dexterity    Int @default(5)
  vitality     Int @default(5)
  intelligence Int @default(5)

  // Full Body Equipment System
  equipHead      String?
  equipCloak     String?
  equipChest     String?
  equipLegs      String?
  equipFeet      String?
  equipHands     String?
  equipNeck      String?
  equipRing1     String?
  equipRing2     String?
  equipMainHand  String?
  equipOffHand   String?

  logs         CombatLog[]
  inventory    InventoryItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CombatLog {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  enemyName String
  outcome   String
  duration  Int
  content   String
  createdAt DateTime @default(now())
}

model InventoryItem {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  templateId String   // The underlying base weapon (e.g. 'musket', 'dagger')
  slot       String   // 'mainhand', 'chest', 'cloak'
  rarity     String   // 'Common', 'Rare', 'Epic', 'Legendary', 'Corrupted'
  name       String   // e.g. "Gleaming Axe of the Bear"
  
  // Procedural Math Data
  weight     Int      @default(0)
  baseStats  Json     // { str: 5, dex: 0, vit: 2... }
  modifiers  Json     // { speedMult: 1.2, acBonus: 5... }
  passives   Json?    // Stores the string keys to the triggers to instantiate in combat
  
  createdAt  DateTime @default(now())
}
