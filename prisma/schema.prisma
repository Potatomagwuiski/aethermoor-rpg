datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Initial model to test database connection and bot mapping
model Player {
  id        String   @id // Discord Application User ID
  name      String   // Username or Nickname
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
