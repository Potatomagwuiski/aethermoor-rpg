generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id // Discord User ID
  level        Int      @default(1)
  xp           Int      @default(0)
  gold         Int      @default(0)
  currentMapId String   @default("whispering_woods")

  // Core Stats
  str              Int @default(5)
  dex              Int @default(5)
  vit              Int @default(5)
  agi              Int @default(5)
  int              Int @default(5)
  unallocatedStats Int @default(0)

  // Equipped Gear Slots (References an InventoryItem.id)
  weaponId String?
  helmetId String?
  amuletId String?
  cloakId  String?
  ring1Id  String?
  ring2Id  String?
  glovesId String?
  armorId  String?
  bootsId  String?

  // Cooldowns
  lastGather DateTime?

  // Virtual relation to their entire inventory
  inventory InventoryItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model InventoryItem {
  id String @id @default(uuid())
  
  userId String
  user   User   @relation(fields: [userId], references: [id])
  
  baseItemId  String // References the static ID from the hardcoded game config
  upgradeTier Int    @default(0) // Ranges from 0 to 15+
  quantity    Int    @default(1)
  
  createdAt DateTime @default(now())
}
