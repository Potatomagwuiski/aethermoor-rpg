// Player Classes have been entirely removed in Phase 18. Identity is now strictly tied to Equipment tags.



enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ToolType {
  PICKAXE
  AXE
  FISHING_ROD
  SICKLE
  HOE
}

enum EquipmentSlot {
  WEAPON
  ARMOR
}

enum EquipmentClass {
  HEAVY_WEAPON
  FINESSE_WEAPON
  MAGIC_WEAPON
  HEAVY_ARMOR
  LIGHT_ARMOR
  CLOTH
  ANY
}

model Player {
  id              String   @id @default(uuid())
  discordId       String   @unique
  name            String
  level           Int      @default(1)
  xp              Int      @default(0)
  gold            Int      @default(0)

  // Vitals
  hp              Int      @default(100)
  maxHp           Int      @default(100)
  energy          Int      @default(100)

  // Geographical Flow
  location        String   @default("lumina_plains")

  // Culinary Buffs
  // Culinary & Progression Trackers
  activeBuff      String?
  buffExpiresAt   DateTime?
  pinnedForgeItems String[] @default([])
  lastDailyQuestRefresh DateTime?

  // Core Allocatable Attributes
  pointsAvailable Int      @default(0)
  str             Int      @default(5)
  agi             Int      @default(5)
  int             Int      @default(5)
  end             Int      @default(5)

  createdAt       DateTime @default(now())
  
  // Relations
  inventory       InventoryItem[]
  equipment       Equipment[]
  tools           Tool[]
  recipes         UnlockedRecipe[]
  pets            Pet[]
  quests          Quest[]
}

model InventoryItem {
  id        String @id @default(uuid())
  playerId  String
  itemKey   String
  quantity  Int    @default(1)

  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, itemKey])
}

model Equipment {
  id            String  @id @default(uuid())
  playerId      String
  equipped      Boolean @default(false)
  baseItemKey   String
  name          String?
  rarity        Rarity  @default(COMMON)
  slot          EquipmentSlot  @default(WEAPON)
  equipmentClass EquipmentClass @default(ANY)
  upgradeLevel  Int     @default(0)
  
  // Procedural Gacha Affixes
  bonusAtk        Int @default(0)
  bonusDef        Int @default(0)
  bonusCrit       Int @default(0)
  bonusLifesteal  Int @default(0)
  bonusEvasion    Int @default(0)

  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Tool {
  id            String  @id @default(uuid())
  playerId      String
  type          ToolType
  equipped      Boolean @default(false)
  name          String?
  rarity        Rarity  @default(COMMON)
  upgradeLevel  Int     @default(0)
  
  // Gathering Progression Affixes
  yieldMultiplier Float @default(1.0)
  monsterRepel    Int   @default(0)
  speedLuck       Int   @default(0)
  activeAbilities String[] @default([])

  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model UnlockedRecipe {
  id        String @id @default(uuid())
  playerId  String
  recipeKey String

  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, recipeKey])
}

model Pet {
  id            String  @id @default(uuid())
  playerId      String
  name          String
  emoji         String
  rarity        Rarity  @default(COMMON)
  level         Int     @default(1)
  
  // Power Scaling
  bonusAtk      Int     @default(0)
  bonusDef      Int     @default(0)
  bonusHp       Int     @default(0)

  equipped      Boolean @default(false)

  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Quest {
  id          String   @id @default(uuid())
  playerId    String
  type        String   // "HUNT", "CHOP", "MINE", "FISH"
  targetVal   Int      
  currentVal  Int      @default(0)
  rewardKey   String   
  rewardQty   Int
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}
