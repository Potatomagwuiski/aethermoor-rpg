{
  "name": "aethermoor-rpg",
  "version": "1.0.0",
  "description": "Discord RPG Game integration with PostgreSQL",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build": "npx prisma db push --accept-data-loss && tsc",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npx prisma generate",
    "db:generate": "prisma generate"
  },
  "keywords": [
    "discord",
    "bot",
    "rpg"
  ],
  "author": "Potatomagwuiski",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
